{
  "name": "@hover-dev/security",
  "version": "0.0.0",
  "description": "Hover plugin: HTTPS MITM proxy, captured-flow inspector, and replay/mutation primitives for AI-driven security testing.",
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "homepage": "https://github.com/Hyperyond/Hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/security"
  },
  "bugs": "https://github.com/Hyperyond/Hover/issues",
  "keywords": [
    "hover",
    "hover-plugin",
    "security",
    "mitm",
    "playwright"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('node:fs').copyFileSync('src/widget.js','dist/widget.js')\"",
    "dev": "tsup --watch",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run clean && pnpm run build",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:e2e": "tsx scripts/e2e-smoke.ts",
    "smoke:plugin": "tsx scripts/plugin-smoke.ts",
    "smoke:mcp": "tsx scripts/mcp-smoke.ts",
    "smoke:agent-cfg": "tsx scripts/agent-config-smoke.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@peculiar/asn1-schema": "2.6.0",
    "mockttp": "^4.4.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "@hover-dev/core": "workspace:*"
  },
  "devDependencies": {
    "@hover-dev/core": "workspace:*",
    "@hover-dev/probe-engine": "workspace:*",
    "playwright-core": "^1.50.0",
    "tsup": "^8.5.1",
    "vitest": "^3.0.0",
    "ws": "^8.20.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
