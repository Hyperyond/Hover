{
  "name": "hover-dev",
  "version": "0.38.0",
  "displayName": "Hover — Vibe Testing cockpit",
  "description": "Open-source, local-first Vibe Testing — the review cockpit. Add Hover's MCP to the coding agent you already run (Claude Code / Codex / Cursor); it explores your app through grounded tools and crystallizes each flow into a plain @playwright/test spec you own, passing CI with zero AI. This extension is where you see it: a Business Map of flows + coverage, a Dashboard of run health synced from GitHub CI or Hover Cloud, and one-click runs. record == replay · API testing · self-heal drifted specs.",
  "keywords": [
    "ai",
    "ai-testing",
    "vibe-testing",
    "vibe-coding",
    "testing",
    "e2e",
    "e2e-testing",
    "playwright",
    "playwright-test",
    "test-automation",
    "qa",
    "web-testing",
    "mcp",
    "business-map",
    "coverage",
    "dashboard",
    "self-heal",
    "ci",
    "github-actions",
    "claude",
    "codex",
    "agent",
    "automation"
  ],
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "publisher": "hyperyond",
  "homepage": "https://www.gethover.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/Hyperyond/Hover/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "AI",
    "Visualization",
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hover.reviewOptimizationCandidate",
        "title": "Review Optimization Candidate",
        "category": "Hover",
        "icon": "$(diff)"
      },
      {
        "command": "hover.healSpec",
        "title": "Heal Spec (in your agent)",
        "category": "Hover",
        "icon": "$(heart)"
      },
      {
        "command": "hover.runSpec",
        "title": "Run Spec",
        "category": "Hover",
        "icon": "$(play)"
      },
      {
        "command": "hover.runFolderSpecs",
        "title": "Run Group",
        "category": "Hover",
        "icon": "$(play)"
      },
      {
        "command": "hover.runAllSpecs",
        "title": "Run All Specs",
        "category": "Hover",
        "icon": "$(run-all)"
      },
      {
        "command": "hover.refreshDashboard",
        "title": "Refresh Dashboard",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.syncCiResults",
        "title": "Sync CI Results",
        "category": "Hover",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hover.startApp",
        "title": "Start App (dev server)",
        "category": "Hover",
        "icon": "$(rocket)"
      },
      {
        "command": "hover.openBusinessMap",
        "title": "Open Business Map",
        "category": "Hover",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "hover.exportMapMermaid",
        "title": "Copy Business Map as Mermaid",
        "category": "Hover",
        "icon": "$(clippy)"
      },
      {
        "command": "hover.openRepo",
        "title": "Star on GitHub",
        "category": "Hover"
      },
      {
        "command": "hover.openSite",
        "title": "Open gethover.dev",
        "category": "Hover"
      },
      {
        "command": "hover.installMcp",
        "title": "Install Hover MCP (add to your coding agent)",
        "category": "Hover",
        "icon": "$(plug)"
      },
      {
        "command": "hover.connectCloud",
        "title": "Sign in to Hover Cloud",
        "category": "Hover",
        "icon": "$(cloud)"
      },
      {
        "command": "hover.disconnectCloud",
        "title": "Sign out of Hover Cloud",
        "category": "Hover",
        "icon": "$(sign-out)"
      },
      {
        "command": "hover.addCiWorkflow",
        "title": "Add CI Workflow (run specs on PR)",
        "category": "Hover",
        "icon": "$(github-action)"
      },
      {
        "command": "hover.refreshEnvironments",
        "title": "Refresh Environments",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.env.add",
        "title": "Add Environment",
        "category": "Hover",
        "icon": "$(add)"
      },
      {
        "command": "hover.env.editUrl",
        "title": "Edit URL",
        "category": "Hover",
        "icon": "$(edit)"
      },
      {
        "command": "hover.env.remove",
        "title": "Remove Environment",
        "category": "Hover",
        "icon": "$(trash)"
      },
      {
        "command": "hover.env.setActive",
        "title": "Set Active Environment",
        "category": "Hover"
      },
      {
        "command": "hover.env.exportEnv",
        "title": "Export Env Vars (copy / .env)",
        "category": "Hover",
        "icon": "$(clippy)"
      },
      {
        "command": "hover.env.syncMcp",
        "title": "Prepare Active Environment for MCP",
        "category": "Hover",
        "icon": "$(sync)"
      },
      {
        "command": "hover.env.addAccount",
        "title": "Add Test Account",
        "category": "Hover",
        "icon": "$(person-add)"
      },
      {
        "command": "hover.env.setPassword",
        "title": "Set / Update Password",
        "category": "Hover",
        "icon": "$(key)"
      },
      {
        "command": "hover.env.removeAccount",
        "title": "Remove Test Account",
        "category": "Hover",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hover",
          "title": "Hover",
          "icon": "resources/hover.svg"
        }
      ]
    },
    "views": {
      "hover": [
        {
          "id": "hover.home",
          "name": "Hover",
          "type": "webview",
          "icon": "$(dashboard)",
          "contextualTitle": "Hover"
        }
      ]
    },
    "configuration": {
      "title": "Hover",
      "properties": {
        "hover.appUrl": {
          "type": "string",
          "default": "",
          "description": "Your dev server URL (e.g. http://localhost:5173). Leave empty to auto-detect common dev ports."
        },
        "hover.cloudUrl": {
          "type": "string",
          "default": "",
          "description": "Hover Cloud base URL. Leave empty for https://cloud.gethover.dev — only set for a self-configured deployment."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "hover.reviewOptimizationCandidate",
          "when": "resourceFilename =~ /\\.spec\\.ts$/",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "hover.refreshDashboard",
          "when": "view == hover.home",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "watch": "tsup --watch",
    "clean:vsix": "node -e \"const fs=require('node:fs');for(const f of fs.readdirSync('.'))if(f.endsWith('.vsix'))fs.rmSync(f)\"",
    "package": "pnpm run clean:vsix && pnpm run build && pnpm run build:webview && pnpm dlx @vscode/vsce package --no-dependencies",
    "publish": "pnpm run build && pnpm run build:webview && pnpm dlx @vscode/vsce publish --no-dependencies",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hover-dev/core": "workspace:*",
    "@xyflow/react": "^12.3.0",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.0.0",
    "vite": "^7.3.3"
  }
}
