{
  "name": "hover-dev",
  "version": "0.14.5",
  "displayName": "Hover — AI Vibe Testing",
  "description": "Vibe-test your app, ship real Playwright specs — local-first, using your own Claude Code / Codex CLI. 🟠 security · 🔴 pentest.",
  "keywords": [
    "ai",
    "ai-testing",
    "vibe-testing",
    "vibe-coding",
    "vibe-test",
    "testing",
    "e2e",
    "end-to-end",
    "playwright",
    "playwright-test",
    "test-automation",
    "qa",
    "web-testing",
    "security",
    "appsec",
    "pentest",
    "authz",
    "idor",
    "bola",
    "claude",
    "codex",
    "agent",
    "automation"
  ],
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "publisher": "hyperyond",
  "homepage": "https://www.gethover.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/Hyperyond/Hover/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "AI",
    "Chat",
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hover.reviewOptimizationCandidate",
        "title": "Review Optimization Candidate",
        "category": "Hover",
        "icon": "$(diff)"
      },
      {
        "command": "hover.openSource",
        "title": "Open Source from Element",
        "category": "Hover"
      },
      {
        "command": "hover.runSpec",
        "title": "Run Spec",
        "category": "Hover",
        "icon": "$(play)"
      },
      {
        "command": "hover.runFolderSpecs",
        "title": "Run Group",
        "category": "Hover",
        "icon": "$(play)"
      },
      {
        "command": "hover.runAllSpecs",
        "title": "Run All Specs",
        "category": "Hover",
        "icon": "$(run-all)"
      },
      {
        "command": "hover.refreshDashboard",
        "title": "Refresh Dashboard",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.resetSourceAccess",
        "title": "Reset Source-Read Permission",
        "category": "Hover"
      },
      {
        "command": "hover.reopenBrowser",
        "title": "Reopen Browser",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.switchMode",
        "title": "Switch Mode (Testing / Security / Pentest)",
        "category": "Hover",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "hover.startEngine",
        "title": "Start Engine",
        "category": "Hover",
        "icon": "$(server-process)"
      },
      {
        "command": "hover.switchAgent",
        "title": "Switch Agent",
        "category": "Hover"
      },
      {
        "command": "hover.newSession",
        "title": "New Session",
        "category": "Hover",
        "icon": "$(add)"
      },
      {
        "command": "hover.saveSpec",
        "title": "Save Last Run as Spec",
        "category": "Hover"
      },
      {
        "command": "hover.saveFindingsReport",
        "title": "Save Findings Report (Pentest)",
        "category": "Hover"
      },
      {
        "command": "hover.cancelRun",
        "title": "Cancel Run",
        "category": "Hover"
      },
      {
        "command": "hover.optimizeSpec",
        "title": "Optimize",
        "category": "Hover",
        "icon": "$(sparkle)"
      },
      {
        "command": "hover.startApp",
        "title": "Start App (dev server + browser)",
        "category": "Hover",
        "icon": "$(rocket)"
      },
      {
        "command": "hover.toggleBrowser",
        "title": "Toggle Browser (Silent / Visible)",
        "category": "Hover",
        "icon": "$(eye)"
      },
      {
        "command": "hover.appStatus",
        "title": "App: Set URL or Start",
        "category": "Hover"
      },
      {
        "command": "hover.openRepo",
        "title": "Star on GitHub",
        "category": "Hover"
      },
      {
        "command": "hover.openSite",
        "title": "Open gethover.dev",
        "category": "Hover"
      },
      {
        "command": "hover.addCiWorkflow",
        "title": "Add CI Workflow (run specs on PR)",
        "category": "Hover",
        "icon": "$(github-action)"
      },
      {
        "command": "hover.refreshSpecs",
        "title": "Refresh Specs",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.refreshEnvironments",
        "title": "Refresh Environments",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.env.add",
        "title": "Add Environment",
        "category": "Hover",
        "icon": "$(add)"
      },
      {
        "command": "hover.env.editUrl",
        "title": "Edit URL",
        "category": "Hover",
        "icon": "$(edit)"
      },
      {
        "command": "hover.env.remove",
        "title": "Remove Environment",
        "category": "Hover",
        "icon": "$(trash)"
      },
      {
        "command": "hover.env.setActive",
        "title": "Set Active Environment",
        "category": "Hover"
      },
      {
        "command": "hover.env.exportEnv",
        "title": "Export Env Vars (copy / .env)",
        "category": "Hover",
        "icon": "$(clippy)"
      },
      {
        "command": "hover.env.addAccount",
        "title": "Add Test Account",
        "category": "Hover",
        "icon": "$(person-add)"
      },
      {
        "command": "hover.env.setPassword",
        "title": "Set / Update Password",
        "category": "Hover",
        "icon": "$(key)"
      },
      {
        "command": "hover.env.removeAccount",
        "title": "Remove Test Account",
        "category": "Hover",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hover-chat",
          "title": "Hover Chat",
          "icon": "resources/hover-chat.svg"
        },
        {
          "id": "hover",
          "title": "Hover",
          "icon": "resources/hover.svg"
        }
      ]
    },
    "views": {
      "hover-chat": [
        {
          "id": "hover.chat",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/hover-chat.svg",
          "contextualTitle": "Hover"
        }
      ],
      "hover": [
        {
          "id": "hover.dashboard",
          "name": "Dashboard",
          "type": "webview",
          "icon": "$(dashboard)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.specs",
          "name": "Specs",
          "icon": "$(beaker)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.sessions",
          "name": "Conversations",
          "type": "webview",
          "icon": "$(comment-discussion)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.environments",
          "name": "Environments",
          "icon": "$(globe)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.settings",
          "name": "Settings",
          "type": "webview",
          "icon": "$(gear)",
          "contextualTitle": "Hover"
        }
      ]
    },
    "configuration": {
      "title": "Hover",
      "properties": {
        "hover.appUrl": {
          "type": "string",
          "default": "",
          "description": "Your dev server URL (e.g. http://localhost:5173). Leave empty to auto-detect common dev ports."
        },
        "hover.browser": {
          "type": "string",
          "enum": [
            "silent",
            "visible"
          ],
          "enumDescriptions": [
            "Headless — no browser window; runs stream into the chat",
            "Visible — show the debug Chrome window"
          ],
          "default": "silent",
          "description": "How Hover runs the browser. Silent = headless (default); Visible = a shown Chrome window you can watch."
        },
        "hover.speech": {
          "type": "boolean",
          "default": false,
          "description": "Speak the agent's steps and final summary aloud while it runs."
        },
        "hover.agent": {
          "type": "string",
          "default": "",
          "description": "Coding-agent CLI to drive runs (e.g. claude / codex). Empty = auto-detect the first installed agent. Switchable from Settings."
        },
        "hover.model": {
          "type": "string",
          "default": "sonnet",
          "description": "Model for runs, switchable from the chat toolbar. Values depend on the active agent (Claude: sonnet / opus / haiku / claude-fable-5; Codex: gpt-5.5 / gpt-5.4 / gpt-5.4-mini)."
        },
        "hover.effort": {
          "type": "string",
          "default": "",
          "description": "Reasoning-effort level for runs, set from the chat model menu. Options depend on the model (Claude: low / medium / high / xhigh / max; Codex: minimal / low / medium / high / xhigh). Empty = the model's default."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "hover.reviewOptimizationCandidate",
          "when": "resourceFilename =~ /\\.spec\\.ts$/",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "hover.runAllSpecs",
          "when": "view == hover.specs",
          "group": "navigation@0"
        },
        {
          "command": "hover.switchMode",
          "when": "view == hover.specs",
          "group": "navigation@1"
        },
        {
          "command": "hover.addCiWorkflow",
          "when": "view == hover.specs",
          "group": "navigation@2"
        },
        {
          "command": "hover.refreshSpecs",
          "when": "view == hover.specs",
          "group": "navigation@3"
        },
        {
          "command": "hover.runAllSpecs",
          "when": "view == hover.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "hover.refreshDashboard",
          "when": "view == hover.dashboard",
          "group": "navigation@2"
        },
        {
          "command": "hover.newSession",
          "when": "view == hover.sessions",
          "group": "navigation@1"
        },
        {
          "command": "hover.env.add",
          "when": "view == hover.environments",
          "group": "navigation@1"
        },
        {
          "command": "hover.refreshEnvironments",
          "when": "view == hover.environments",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hover.env.addAccount",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Local|Unverified)?$/",
          "group": "inline@1"
        },
        {
          "command": "hover.env.exportEnv",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Local|Unverified)?$/",
          "group": "inline@2"
        },
        {
          "command": "hover.env.editUrl",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Unverified)?$/",
          "group": "1_env@1"
        },
        {
          "command": "hover.env.exportEnv",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Local|Unverified)?$/",
          "group": "1_env@2"
        },
        {
          "command": "hover.env.addAccount",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Local|Unverified)?$/",
          "group": "1_env@2"
        },
        {
          "command": "hover.env.remove",
          "when": "view == hover.environments && viewItem =~ /^hoverEnv(Unverified)?$/",
          "group": "1_env@3"
        },
        {
          "command": "hover.env.setPassword",
          "when": "view == hover.environments && viewItem == hoverAccount",
          "group": "inline@1"
        },
        {
          "command": "hover.env.removeAccount",
          "when": "view == hover.environments && viewItem == hoverAccount",
          "group": "inline@2"
        },
        {
          "command": "hover.runSpec",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "inline@1"
        },
        {
          "command": "hover.optimizeSpec",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "inline@2"
        },
        {
          "command": "hover.runFolderSpecs",
          "when": "view == hover.specs && viewItem == hoverFolder",
          "group": "inline@1"
        },
        {
          "command": "hover.optimizeSpec",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "1_hover@1"
        },
        {
          "command": "hover.reviewOptimizationCandidate",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "1_hover@3"
        },
        {
          "command": "hover.runSpec",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "1_hover@4"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hover.specs",
        "contents": "No specs yet.\n\nDrive your app with Hover to crystallize a test or security check into a Playwright spec, then it shows up here."
      }
    ]
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "stage:engine": "node scripts/stage-engine.mjs",
    "clean:vsix": "node -e \"const fs=require('node:fs');for(const f of fs.readdirSync('.'))if(f.endsWith('.vsix'))fs.rmSync(f)\"",
    "package": "pnpm run clean:vsix && pnpm run build && pnpm run stage:engine && pnpm dlx @vscode/vsce package --no-dependencies",
    "publish": "pnpm run build && pnpm run stage:engine && pnpm dlx @vscode/vsce publish --no-dependencies",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0"
  }
}
