{
  "name": "hover-dev",
  "version": "0.5.0",
  "displayName": "Hover — AI E2E Testing & Security",
  "description": "AI test authoring + application-security (authz / BOLA) testing in one extension — explore your app, crystallize verified flows into plain Playwright specs that run in CI with no AI.",
  "keywords": ["ai", "testing", "e2e", "end-to-end", "playwright", "security", "appsec", "authz", "bola", "idor", "test-automation"],
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "publisher": "hyperyond",
  "homepage": "https://github.com/Hyperyond/Hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/vscode-ext"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Testing", "Other"],
  "main": "./dist/extension.cjs",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "hover.reviewOptimizationCandidate",
        "title": "Review Optimization Candidate",
        "category": "Hover",
        "icon": "$(diff)"
      },
      {
        "command": "hover.openSource",
        "title": "Open Source from Element",
        "category": "Hover"
      },
      {
        "command": "hover.newProbeSeed",
        "title": "New Probe Seed",
        "category": "Hover",
        "icon": "$(add)"
      },
      {
        "command": "hover.runSpec",
        "title": "Run Spec",
        "category": "Hover",
        "icon": "$(play)"
      },
      {
        "command": "hover.switchMode",
        "title": "Switch Mode (Testing / Security / Pentest)",
        "category": "Hover",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "hover.startEngine",
        "title": "Start Engine",
        "category": "Hover",
        "icon": "$(server-process)"
      },
      {
        "command": "hover.switchAgent",
        "title": "Switch Agent",
        "category": "Hover"
      },
      {
        "command": "hover.newSession",
        "title": "New Session",
        "category": "Hover",
        "icon": "$(add)"
      },
      {
        "command": "hover.saveSpec",
        "title": "Save Last Run as Spec",
        "category": "Hover"
      },
      {
        "command": "hover.cancelRun",
        "title": "Cancel Run",
        "category": "Hover"
      },
      {
        "command": "hover.openRepo",
        "title": "Star on GitHub",
        "category": "Hover"
      },
      {
        "command": "hover.refreshSpecs",
        "title": "Refresh Specs",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.refreshSessions",
        "title": "Refresh Sessions",
        "category": "Hover",
        "icon": "$(refresh)"
      },
      {
        "command": "hover.refreshSeeds",
        "title": "Refresh Seeds",
        "category": "Hover",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hover-chat",
          "title": "Hover Chat",
          "icon": "resources/hover-chat.svg"
        },
        {
          "id": "hover",
          "title": "Hover",
          "icon": "resources/hover.svg"
        }
      ]
    },
    "views": {
      "hover-chat": [
        {
          "id": "hover.chat",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/hover-chat.svg",
          "contextualTitle": "Hover"
        }
      ],
      "hover": [
        {
          "id": "hover.specs",
          "name": "Specs",
          "icon": "$(beaker)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.sessions",
          "name": "Sessions",
          "icon": "$(history)",
          "contextualTitle": "Hover"
        },
        {
          "id": "hover.seeds",
          "name": "Probe Seeds",
          "icon": "$(law)",
          "contextualTitle": "Hover"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": ["**/.hover/rules/security/*.json", "**/.hover/rules/security/**/*.json"],
        "url": "./schemas/hover-security-seed.schema.json"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "hover.reviewOptimizationCandidate",
          "when": "resourceFilename =~ /\\.spec\\.ts$/",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "hover.switchMode",
          "when": "view == hover.specs",
          "group": "navigation@1"
        },
        {
          "command": "hover.newProbeSeed",
          "when": "view == hover.specs",
          "group": "navigation@2"
        },
        {
          "command": "hover.refreshSpecs",
          "when": "view == hover.specs",
          "group": "navigation@3"
        },
        {
          "command": "hover.newSession",
          "when": "view == hover.sessions",
          "group": "navigation@1"
        },
        {
          "command": "hover.refreshSessions",
          "when": "view == hover.sessions",
          "group": "navigation@2"
        },
        {
          "command": "hover.newProbeSeed",
          "when": "view == hover.seeds",
          "group": "navigation@1"
        },
        {
          "command": "hover.refreshSeeds",
          "when": "view == hover.seeds",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "hover.runSpec",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "inline@1"
        },
        {
          "command": "hover.reviewOptimizationCandidate",
          "when": "view == hover.specs && viewItem =~ /hover(Security)?Spec/",
          "group": "inline@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hover.specs",
        "contents": "No specs yet.\n\nDrive your app with Hover to crystallize a test or security check into a Playwright spec, then it shows up here.\n\n[New Probe Seed](command:hover.newProbeSeed)"
      },
      {
        "view": "hover.sessions",
        "contents": "No Hover runs recorded yet.\n\nStart a chat to drive your app — each run (model, cost, outcome) is logged here.\n\n[New Session](command:hover.newSession)"
      },
      {
        "view": "hover.seeds",
        "contents": "No project probe seeds yet.\n\nProbe seeds under .hover/rules/security/ teach Hover what to test for (IDOR/BOLA, injection, …).\n\n[New Probe Seed](command:hover.newProbeSeed)"
      }
    ]
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "stage:engine": "node scripts/stage-engine.mjs",
    "package": "pnpm run build && pnpm run stage:engine && pnpm dlx @vscode/vsce package --no-dependencies",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0"
  }
}
