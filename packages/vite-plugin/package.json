{
  "name": "@hyperyond/vite-plugin",
  "version": "0.0.0",
  "description": "Vite plugin that injects the Hover chat widget into your dev server, so AI can drive your real Chrome.",
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "homepage": "https://github.com/Hyperyond/Hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/vite-plugin"
  },
  "bugs": "https://github.com/Hyperyond/Hover/issues",
  "keywords": ["hover", "vite", "vite-plugin", "playwright", "browser-testing", "claude"],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').cpSync('src/widget','dist/widget',{recursive:true})\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@hyperyond/core": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
