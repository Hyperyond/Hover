{
  "name": "@hover-dev/cli",
  "version": "0.0.0",
  "description": "Hover CLI — autonomous test-suite authoring in a Claude-Code-style terminal UI",
  "private": true,
  "type": "module",
  "bin": {
    "hover": "./dist/cli.js",
    "hover-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@hover-dev/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.1.0",
    "playwright-core": "^1.50.0",
    "react": "^19.2.6",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
