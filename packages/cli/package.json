{
  "name": "@hover-dev/cli",
  "version": "0.0.0",
  "description": "CLI for Hover. Detects your bundler, installs the right Hover integration package, and wires it into your config — one command.",
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "homepage": "https://github.com/Hyperyond/Hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/Hyperyond/Hover/issues",
  "keywords": ["hover", "cli", "scaffold", "vite", "astro", "nuxt", "webpack", "playwright", "claude"],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "magicast": "^0.5.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
      "hover": "dist/index.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
