{
  "name": "@hover-dev/core",
  "version": "0.0.0",
  "description": "Hover's local Node service: agent invocation, Playwright CDP preflight, WebSocket bridge.",
  "license": "Apache-2.0",
  "author": "Hyperyond",
  "homepage": "https://github.com/Hyperyond/Hover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperyond/Hover.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/Hyperyond/Hover/issues",
  "keywords": [
    "hover",
    "playwright",
    "mcp",
    "agent",
    "browser-testing",
    "claude"
  ],
  "type": "module",
  "main": "dist/engine.js",
  "types": "dist/engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./wiki": {
      "types": "./dist/wiki.d.ts",
      "import": "./dist/wiki.js"
    }
  },
  "files": [
    "dist",
    "seeds",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cross-spawn": "^7.0.6",
    "playwright-core": "^1.50.0",
    "ts-morph": "^28.0.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/ws": "^8.18.1",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "bin": {
      "hover-chrome": "dist/scripts/start-chrome.js"
    }
  }
}
