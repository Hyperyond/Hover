{
  "name": "hover",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AI that hovers over your dev workflow. Natural language frontend testing.",
  "license": "Apache-2.0",
  "scripts": {
    "dev:site": "pnpm --filter @hover-dev/site dev",
    "build:site": "pnpm --filter @hover-dev/site build",
    "typecheck": "pnpm -r --filter './packages/*' exec tsc --noEmit && pnpm --filter @hover-dev/site typecheck",
    "build": "pnpm --filter @hover-dev/probe-engine --filter @hover-dev/core --filter @hover-dev/api-test --filter @hover-dev/pentest --filter @hover-dev/mcp build",
    "package": "pnpm --filter hover-dev package",
    "clean": "pnpm --filter @hover-dev/core --filter @hover-dev/api-test --filter @hover-dev/pentest clean",
    "test": "pnpm -r --if-present test",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "postinstall": "node scripts/postinstall-build.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.0",
    "@commitlint/config-conventional": "^19.7.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "tsx": "^4.22.0",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "overrides": {
      "@peculiar/asn1-cms": "2.6.1",
      "@peculiar/asn1-csr": "2.6.1",
      "@peculiar/asn1-ecc": "2.6.1",
      "@peculiar/asn1-pfx": "2.7.0",
      "@peculiar/asn1-pkcs8": "2.6.1",
      "@peculiar/asn1-pkcs9": "2.6.1",
      "@peculiar/asn1-rsa": "2.6.1",
      "@peculiar/asn1-schema": "2.6.0",
      "@peculiar/asn1-x509": "2.6.1",
      "@peculiar/asn1-x509-attr": "2.6.1"
    }
  }
}
