{
  "name": "hover",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AI that hovers over your dev workflow. Natural language frontend testing.",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "pnpm -r --filter './packages/*' exec tsc --noEmit",
    "build": "pnpm --filter @hover-dev/core --filter @hover-dev/mcp build",
    "package": "pnpm --filter hover-dev package",
    "clean": "pnpm --filter @hover-dev/core --filter @hover-dev/mcp clean",
    "test": "pnpm -r --if-present test",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "postinstall": "node scripts/postinstall-build.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.0",
    "@commitlint/config-conventional": "^19.7.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "tsx": "^4.22.0",
    "typescript": "^5.9.0"
  }
}
